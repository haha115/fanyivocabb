<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Ôn từ vựng Việt - Trung | Lật thẻ thông minh + Random</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(145deg, #f0f7ff 0%, #e9eef5 100%);
            font-family: 'Segoe UI', 'Roboto', 'Noto Sans', system-ui, -apple-system, 'Helvetica Neue', sans-serif;
            padding: 2rem 1.5rem;
            color: #1a2c3e;
        }

        .app-container {
            max-width: 1400px;
            margin: 0 auto;
        }

        /* header */
        .header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .header h1 {
            font-size: 2.4rem;
            background: linear-gradient(135deg, #1e5a7d, #0f3b4f);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            letter-spacing: -0.5px;
            display: inline-flex;
            align-items: center;
            gap: 12px;
        }

        .header h1::before {
            content: "📖";
            font-size: 2rem;
            background: none;
            color: #2c6e9e;
        }

        .sub {
            color: #4a627a;
            margin-top: 8px;
            font-weight: 500;
            border-bottom: 2px solid #cbdbe6;
            display: inline-block;
            padding-bottom: 5px;
        }

        /* stats & filter */
        .stats-bar {
            background: white;
            border-radius: 40px;
            padding: 12px 20px;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            gap: 15px;
            margin-bottom: 28px;
            box-shadow: 0 8px 18px rgba(0,0,0,0.05);
            border: 1px solid rgba(255,255,255,0.5);
        }

        .info-badge {
            background: #eef2fa;
            padding: 6px 16px;
            border-radius: 40px;
            font-weight: 600;
            color: #1f5e8c;
        }

        .info-badge span {
            font-size: 1.3rem;
            font-weight: 800;
            margin: 0 4px;
        }

        .filter-group {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .search-box {
            background: #f8fafd;
            border: 1px solid #cbdde9;
            border-radius: 48px;
            padding: 8px 18px;
            width: 260px;
            font-size: 0.9rem;
            transition: all 0.2s;
        }

        .search-box:focus {
            outline: none;
            border-color: #2c7ab1;
            box-shadow: 0 0 0 3px rgba(44,122,177,0.2);
        }

        .btn-reset {
            background: #e2e8f0;
            border: none;
            border-radius: 32px;
            padding: 0 18px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            color: #2c3e50;
        }

        .btn-reset:hover {
            background: #cbd5e1;
        }
        
        /* Nút random mới */
        .btn-random {
            background: linear-gradient(135deg, #6c5ce7, #a363d9);
            border: none;
            border-radius: 32px;
            padding: 0 18px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            color: white;
            box-shadow: 0 2px 6px rgba(108,92,231,0.3);
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .btn-random:hover {
            background: linear-gradient(135deg, #5b4bc4, #8e53c2);
            transform: scale(0.97);
            box-shadow: 0 4px 10px rgba(108,92,231,0.4);
        }

        /* layout */
        .study-layout {
            display: grid;
            grid-template-columns: 1fr 380px;
            gap: 28px;
        }

        @media (max-width: 860px) {
            .study-layout {
                grid-template-columns: 1fr;
            }
            body {
                padding: 1rem;
            }
        }

        /* flashcard với hiệu ứng lật 3D */
        .flashcard-area {
            background: transparent;
            border-radius: 36px;
            height: fit-content;
            position: sticky;
            top: 20px;
            perspective: 1500px;
        }

        .card-mode-title {
            text-align: center;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #5d7b9a;
            margin-bottom: 16px;
        }

        .flip-card {
            background-color: transparent;
            width: 100%;
            height: 340px;
            cursor: pointer;
        }

        .flip-card-inner {
            position: relative;
            width: 100%;
            height: 100%;
            text-align: center;
            transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
            transform-style: preserve-3d;
            border-radius: 32px;
            box-shadow: 0 25px 35px -12px rgba(0,0,0,0.2);
        }

        .flipped .flip-card-inner {
            transform: rotateY(180deg);
        }

        .front, .back {
            position: absolute;
            width: 100%;
            height: 100%;
            backface-visibility: hidden;
            border-radius: 32px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 2rem;
            background: white;
            box-sizing: border-box;
        }

        .front {
            background: linear-gradient(135deg, #ffffff, #f9fcff);
            border: 1px solid rgba(60, 130, 180, 0.2);
        }

        .back {
            background: linear-gradient(135deg, #fffaf5, #fff5ed);
            transform: rotateY(180deg);
            border: 1px solid #e0c8b8;
        }

        .term-viet {
            font-size: 1.8rem;
            font-weight: 700;
            color: #1a5d7d;
            margin-bottom: 20px;
            word-break: break-word;
            line-height: 1.3;
        }

        .meaning-chinese {
            font-size: 1.4rem;
            font-weight: 500;
            color: #b1624b;
            background: #fff3ed;
            display: inline-block;
            padding: 8px 24px;
            border-radius: 60px;
            word-break: break-word;
            line-height: 1.4;
        }

        .card-hint {
            margin-top: 28px;
            font-size: 0.8rem;
            color: #8899b0;
            font-style: italic;
        }

        .nav-buttons {
            display: flex;
            justify-content: center;
            gap: 25px;
            margin-top: 28px;
        }

        .nav-btn {
            background: #eef3fc;
            border: none;
            font-size: 1.1rem;
            font-weight: bold;
            padding: 10px 22px;
            border-radius: 60px;
            cursor: pointer;
            transition: 0.2s;
            color: #2c6285;
            display: inline-flex;
            gap: 8px;
            align-items: center;
        }

        .nav-btn:hover {
            background: #dce7f2;
            transform: scale(0.97);
        }

        .progress-text {
            text-align: center;
            margin-top: 18px;
            font-size: 0.85rem;
            font-weight: 500;
            color: #456e8c;
        }

        /* danh sách từ vựng */
        .vocab-list {
            background: rgba(255,255,240,0.3);
            border-radius: 32px;
            padding: 8px 6px;
        }

        .list-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: 18px;
            padding: 0 10px;
            flex-wrap: wrap;
            gap: 10px;
        }

        .list-header h2 {
            font-size: 1.4rem;
            font-weight: 600;
        }

        .badge-learn {
            background: #f0f4f9;
            border-radius: 30px;
            font-size: 0.7rem;
            padding: 4px 12px;
            color: #497e9e;
        }

        .cards-grid {
            display: flex;
            flex-direction: column;
            gap: 12px;
            max-height: 70vh;
            overflow-y: auto;
            padding-right: 6px;
        }

        .vocab-item {
            background: white;
            border-radius: 24px;
            padding: 14px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 10px;
            transition: all 0.2s;
            box-shadow: 0 2px 6px rgba(0,0,0,0.05);
            border-left: 6px solid #6da5c9;
            cursor: pointer;
        }

        .vocab-item:hover {
            background: #fefcf5;
            transform: translateX(4px);
            border-left-color: #e0876a;
        }

        .viet-part {
            font-weight: 700;
            font-size: 1rem;
            color: #1e4d6b;
            min-width: 180px;
            word-break: break-word;
            flex: 2;
        }

        .chi-part {
            color: #b45f3b;
            font-weight: 500;
            font-size: 0.9rem;
            text-align: right;
            flex: 2;
            word-break: break-word;
        }

        @media (max-width: 550px) {
            .vocab-item {
                flex-direction: column;
                align-items: flex-start;
            }
            .chi-part {
                text-align: left;
            }
            .term-viet {
                font-size: 1.3rem;
            }
            .meaning-chinese {
                font-size: 1.1rem;
            }
            .flip-card {
                height: 300px;
            }
            .stats-bar {
                flex-direction: column;
                align-items: stretch;
            }
            .filter-group {
                justify-content: center;
            }
        }

        footer {
            margin-top: 40px;
            text-align: center;
            font-size: 0.75rem;
            color: #6f8eaa;
            border-top: 1px solid #d0e0ec;
            padding-top: 24px;
        }
        
        .random-active-badge {
            background: #e9d8fd;
            color: #6c5ce7;
            font-size: 0.7rem;
            border-radius: 20px;
            padding: 4px 12px;
            margin-left: 10px;
            font-weight: normal;
        }
    </style>
</head>
