                    </div>
                </div>
            </div>
            <div class="nav-buttons">
                <button class="nav-btn" id="prevBtn">◀ Trước</button>
                <button class="nav-btn" id="nextBtn">Sau ▶</button>
            </div>
            <div class="progress-text" id="cardProgress"></div>
        </div>

        <!-- Danh sách từ vựng -->
        <div class="vocab-list">
            <div class="list-header">
                <h2>📖 Kho từ vựng <span id="randomIndicator" class="random-active-badge" style="display: none;">🎲 Chế độ random</span></h2>
                <div class="badge-learn">📌 Bấm vào từ để chọn & học</div>
            </div>
            <div class="cards-grid" id="vocabGrid"></div>
        </div>
    </div>
    <footer>📌 Ôn tập cá nhân · Lật thẻ mượt mà · Random giúp ghi nhớ sâu hơn</footer>
</div>

