    let masterVocab = rawVocabulary.map(([viet, chi]) => ({ viet: viet.trim(), chi: chi }));
    let filteredData = [...masterVocab];
    let currentCardIndex = 0;
    let isRandomMode = false;       // Trạng thái random (chỉ để hiển thị badge)
    let lastSearchTerm = "";        // Lưu lại từ khóa tìm kiếm để random không làm mất filter

    // DOM elements
    const totalSpan = document.getElementById("totalCount");
    const vocabGrid = document.getElementById("vocabGrid");
    const searchInput = document.getElementById("searchInput");
    const resetBtn = document.getElementById("resetFilterBtn");
    const randomBtn = document.getElementById("randomBtn");
    const cardViet = document.getElementById("cardViet");
    const cardChinese = document.getElementById("cardChinese");
    const prevBtn = document.getElementById("prevBtn");
    const nextBtn = document.getElementById("nextBtn");
    const cardProgress = document.getElementById("cardProgress");
    const flipCardContainer = document.getElementById("flipCard");
    const randomIndicatorSpan = document.getElementById("randomIndicator");

    // Xử lý lật thẻ
    function setFlipState(flipped) {
        if (flipped) {
            flipCardContainer.classList.add('flipped');
        } else {
            flipCardContainer.classList.remove('flipped');
        }
    }

    function resetFlip() {
        setFlipState(false);
    }

    // Cập nhật flashcard theo currentCardIndex
    function updateFlashcardByIndex() {
        if (filteredData.length === 0) {
            cardViet.innerText = "📭 Không có từ phù hợp";
            cardChinese.innerText = "Hãy xóa bộ lọc hoặc random lại";
            cardProgress.innerText = "0 / 0";
            resetFlip();
            return;
        }
        const item = filteredData[currentCardIndex];
        if (item) {
            cardViet.innerText = item.viet;
            cardChinese.innerHTML = item.chi;
            cardProgress.innerText = `${currentCardIndex+1} / ${filteredData.length}`;
            resetFlip();
        }
    }

    // Render danh sách từ vựng bên cạnh
    function renderVocabList() {
        if (filteredData.length === 0) {
            vocabGrid.innerHTML = `<div style="padding: 2rem; text-align:center; background: #fff4e8; border-radius: 32px;">✨ Không tìm thấy từ vựng nào. Thử nhập từ khóa khác hoặc random nhé!</div>`;
            return;
        }
        let html = "";
        filteredData.forEach((item, idx) => {
            const displayChi = item.chi.length > 70 ? item.chi.substring(0, 70) + "…" : item.chi;
            html += `
                <div class="vocab-item" data-index="${idx}">
                    <div class="viet-part">${escapeHtml(item.viet)}</div>
                    <div class="chi-part">${escapeHtml(displayChi)}</div>
                    <div class="badge-learn">📌 chọn</div>
                </div>
            `;
        });
        vocabGrid.innerHTML = html;
        document.querySelectorAll('.vocab-item').forEach(el => {
            el.addEventListener('click', (e) => {
                const idxAttr = el.getAttribute('data-index');
                if (idxAttr !== null) {
                    const newIdx = parseInt(idxAttr, 10);
                    if (!isNaN(newIdx) && newIdx >= 0 && newIdx < filteredData.length) {
                        currentCardIndex = newIdx;
                        updateFlashcardByIndex();
                    }
                }
            });
        });
    }

    // Hàm xáo trộn mảng (Fisher-Yates)
    function shuffleArray(arr) {
        for (let i = arr.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [arr[i], arr[j]] = [arr[j], arr[i]];
        }
        return arr;
    }

    // Random toàn bộ danh sách đang hiển thị (giữ nguyên filter)
    function applyRandomOrder() {
        if (filteredData.length === 0) {
            // Nếu đang không có từ nào thì không random
            return;
        }
        // Xáo trộn filteredData hiện tại
        filteredData = shuffleArray([...filteredData]);
        currentCardIndex = 0;
        isRandomMode = true;
        randomIndicatorSpan.style.display = "inline-block";
        // Cập nhật giao diện
        renderVocabList();
        updateFlashcardByIndex();
    }

    // Lọc từ vựng theo từ khóa, đồng thời reset random mode (vì lọc tạo thứ tự mặc định)
    function filterVocabulary() {
        const searchTerm = searchInput.value.trim().toLowerCase();
        lastSearchTerm = searchTerm;
        let newFiltered;
        if (searchTerm === "") {
            newFiltered = [...masterVocab];
        } else {
            newFiltered = masterVocab.filter(item => 
                item.viet.toLowerCase().includes(searchTerm) || 
                item.chi.toLowerCase().includes(searchTerm)
            );
        }
        filteredData = newFiltered;
        currentCardIndex = 0;
        isRandomMode = false;
        randomIndicatorSpan.style.display = "none";
        updateStatsAndList();
    }

    // Reset filter: xóa tìm kiếm, thoát random, về master gốc
    function resetFilter() {
        searchInput.value = "";
        lastSearchTerm = "";
        filteredData = [...masterVocab];
        currentCardIndex = 0;
        isRandomMode = false;
        randomIndicatorSpan.style.display = "none";
        updateStatsAndList();
    }

    // Random nhưng vẫn giữ nguyên điều kiện lọc hiện tại (nếu đang lọc thì random trong các từ đã lọc)
    function randomizeCurrentList() {
        if (filteredData.length === 0) {
            // Nếu không có từ nào, không thể random
            return;
        }
        // Xáo trộn filteredData hiện tại
        filteredData = shuffleArray([...filteredData]);
        currentCardIndex = 0;
        isRandomMode = true;
        randomIndicatorSpan.style.display = "inline-block";
        renderVocabList();
        updateFlashcardByIndex();
    }

    function nextCard() {
        if (filteredData.length === 0) return;
        currentCardIndex = (currentCardIndex + 1) % filteredData.length;
        updateFlashcardByIndex();
    }

    function prevCard() {
        if (filteredData.length === 0) return;
        currentCardIndex = (currentCardIndex - 1 + filteredData.length) % filteredData.length;
        updateFlashcardByIndex();
    }

    function updateStatsAndList() {
        totalSpan.innerText = filteredData.length;
        renderVocabList();
        updateFlashcardByIndex();
    }

    function escapeHtml(str) {
        if (!str) return "";
        return str.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }

    // Sự kiện lật thẻ
    flipCardContainer.addEventListener("click", (e) => {
        if (filteredData.length === 0) return;
        flipCardContainer.classList.toggle('flipped');
    });

    // Khởi tạo và gắn sự kiện
    function init() {
        filterVocabulary();  // hiển thị toàn bộ danh sách ban đầu
        searchInput.addEventListener("input", () => {
            // Khi gõ tìm kiếm, tự động filter và thoát random
            filterVocabulary();
        });
        resetBtn.addEventListener("click", resetFilter);
        randomBtn.addEventListener("click", randomizeCurrentList);
        prevBtn.addEventListener("click", prevCard);
        nextBtn.addEventListener("click", nextCard);
    }

    init();
</script>
